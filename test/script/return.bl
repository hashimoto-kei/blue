func factorial(n) {
  if (n == 0) {
    return 1;
  }
  n * factorial(n - 1);
}

for (var i = 0; i < 10; i = i + 1) {
  print factorial(i);
}

func fibonacci(n) {
  if (n == 0 or n == 1) {
    return 1;
  }
  return fibonacci(n - 2) + fibonacci(n - 1);
}

for (var i = 0; i < 10; i = i + 1) {
  print fibonacci(i);
}

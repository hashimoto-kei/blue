func add2(x, y) {
  x + y;
}
print add2(1, 2);

func add3(x, y, z) {
  x + y + z;
}
print add3(1, 2, 3);

func factorial(n) {
  if (n == 0) {
    1;
  } else {
    n * factorial(n - 1);
  }
}
print factorial(0);
print factorial(1);
print factorial(2);
print factorial(3);
print factorial(4);
print factorial(5);
